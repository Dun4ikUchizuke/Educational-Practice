<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Unlearn.Controls"
             x:Class="Unlearn.MainPage"
             BackgroundColor="#151515">

    <ContentPage.Resources>

        <Style x:Key="PillLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextColor" Value="#EDEDED" />
            <Setter Property="Opacity" Value="0.70" />
        </Style>

        <Style x:Key="PillValueStyle" TargetType="Label">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="TextColor" Value="#FFFFFF" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Opacity" Value="0.95" />
        </Style>

        <LinearGradientBrush x:Key="CardBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#232323" Offset="0" />
            <GradientStop Color="#1B1B1B" Offset="0.55" />
            <GradientStop Color="#151515" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GreenPillBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1D6E52" Offset="0" />
            <GradientStop Color="#12382C" Offset="1" />
        </LinearGradientBrush>

    </ContentPage.Resources>

    <Grid RowDefinitions="64,*">

        <!-- TOP BAR -->
        <Grid Grid.Row="0"
              BackgroundColor="#184C3A"
              Padding="16,10"
              ColumnDefinitions="Auto,*,Auto">

            <Image Source="lotus_small.png"
                   WidthRequest="26"
                   HeightRequest="26"
                   VerticalOptions="Center" />

            <Label Grid.Column="1"
                   Text="UnlearnIt"
                   TextColor="#EDEDED"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />

            <Button Grid.Column="2"
                    Text="☰"
                    FontSize="24"
                    TextColor="#EDEDED"
                    BackgroundColor="Transparent"
                    WidthRequest="44"
                    HeightRequest="44"
                    Padding="0"
                    Clicked="OnMenuClicked" />
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1"
              Padding="{OnIdiom Phone='14,16', Tablet='24,22', Desktop='34,26'}">

            <CollectionView x:Name="HabitsCollection"
                            ItemsSource="{Binding Habits}"
                            SelectionMode="None">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border Margin="10"
                                Padding="20"
                                Stroke="#5A5A5A"
                                StrokeThickness="1"
                                Background="{StaticResource CardBackgroundBrush}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="44" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="#000000"
                                        Offset="0,14"
                                        Radius="30"
                                        Opacity="0.35" />
                            </Border.Shadow>

                            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">

                                <!-- progress + lotus -->
                                <Grid HeightRequest="{OnIdiom Phone=210, Tablet=230, Desktop=240}">

                                    <controls:CircularProgressView Progress="{Binding Progress}"
                                                                   StrokeThickness="{OnIdiom Phone=12, Tablet=12, Desktop=12}"
                                                                   TrackColor="#2C2C2C"
                                                                   ProgressColor="{Binding Accent}"
                                                                   WidthRequest="{OnIdiom Phone=200, Tablet=210, Desktop=220}"
                                                                   HeightRequest="{OnIdiom Phone=200, Tablet=210, Desktop=220}"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center" />

                                    <Image Source="{Binding CenterImage}"
                                           WidthRequest="{OnIdiom Phone=140, Tablet=150, Desktop=160}"
                                           HeightRequest="{OnIdiom Phone=140, Tablet=150, Desktop=160}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Grid>

                                <!-- title -->
                                <Label Text="{Binding Title}"
                                       FontSize="{OnIdiom Phone=26, Tablet=30, Desktop=32}"
                                       TextColor="#F2F2F2"
                                       Margin="4,0,0,0" />

                                <!-- pills -->
                                <VerticalStackLayout Grid.Row="2" Spacing="14">

                                    <Border Padding="18,12"
                                            Opacity="0.95"
                                            Background="{StaticResource GreenPillBrush}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="22" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Pill1Label}" Style="{StaticResource PillLabelStyle}" />
                                            <Label Text="{Binding Pill1Value}" Style="{StaticResource PillValueStyle}" />
                                        </VerticalStackLayout>
                                    </Border>

                                    <Border Padding="18,12"
                                            Opacity="0.90"
                                            Background="{StaticResource GreenPillBrush}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="22" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Pill2Label}" Style="{StaticResource PillLabelStyle}" />
                                            <Label Text="{Binding Pill2Value}" Style="{StaticResource PillValueStyle}" />
                                        </VerticalStackLayout>
                                    </Border>

                                    <Border Padding="18,12"
                                            Opacity="0.95"
                                            Background="{StaticResource GreenPillBrush}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="22" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Pill3Label}" Style="{StaticResource PillLabelStyle}" />
                                            <Label Text="{Binding Pill3Value}" Style="{StaticResource PillValueStyle}" />
                                        </VerticalStackLayout>
                                    </Border>

                                </VerticalStackLayout>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- ADD NEW CARD -->
                <CollectionView.Footer>
                    <Border Margin="10"
                            Padding="26"
                            Stroke="#5A5A5A"
                            StrokeThickness="1"
                            Background="{StaticResource CardBackgroundBrush}"
                            HeightRequest="{OnIdiom Phone=240, Tablet=280, Desktop=320}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="54" />
                        </Border.StrokeShape>

                        <Border.Shadow>
                            <Shadow Brush="#000000"
                                    Offset="0,14"
                                    Radius="30"
                                    Opacity="0.35" />
                        </Border.Shadow>

                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="10"
                              HorizontalOptions="Center"
                              VerticalOptions="Center">
                            <Label Text="+"
                                   FontSize="{OnIdiom Phone=78, Tablet=90, Desktop=98}"
                                   TextColor="#EDEDED"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Row="1"
                                   Text="Создать новый отказ"
                                   FontSize="{OnIdiom Phone=18, Tablet=22, Desktop=26}"
                                   TextColor="#EDEDED"
                                   HorizontalTextAlignment="Center" />
                        </Grid>

                        <!-- ВАЖНО: тап открывает модальное окно -->
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAddNewTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </CollectionView.Footer>

            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>